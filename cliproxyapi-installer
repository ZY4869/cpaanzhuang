CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Track temporary files created by this script (cleaned up on exit)
TEMP_FILES=()
RESTART_TIMER_STATUS="not_configured"
RESTART_TIMER_ON_CALENDAR=""
RESTART_TIMER_TIMEZONE=""

# Logging functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "${CYAN}[STEP]${NC} $1"
}

get_systemd_user_dir() {
    echo "$HOME/.config/systemd/user"
}

get_systemctl_bin() {
    command -v systemctl 2>/dev/null || echo "/usr/bin/systemctl"
}

get_system_timezone() {
    local timezone=""

    if command -v timedatectl >/dev/null 2>&1; then
        timezone=$(timedatectl show -p Timezone --value 2>/dev/null || true)
    fi

    if [[ -z "$timezone" && -f /etc/timezone ]]; then
        timezone=$(tr -d '[:space:]' </etc/timezone)
    fi

    if [[ -z "$timezone" && -n "${TZ:-}" ]]; then
        timezone="$TZ"
    fi

    if [[ -z "$timezone" ]]; then
        local utc_offset
        utc_offset=$(date +%z 2>/dev/null || true)
        if [[ "$utc_offset" == "+0000" ]]; then
            timezone="UTC"
        else
            timezone="LOCAL"
        fi
    fi

    echo "$timezone"
}

get_restart_timer_calendar() {
    local timezone="$1"

    if [[ "$timezone" == "UTC" || "$timezone" == "Etc/UTC" ]]; then
        echo "*-*-* 20:00:00"
    else
        echo "*-*-* 04:00:00"
    fi
}

get_restart_timer_on_calendar() {
    local timer_file
    timer_file="$(get_systemd_user_dir)/cliproxyapi-restart.timer"

    if [[ ! -f "$timer_file" ]]; then
        timer_file="${INSTALL_DIR}/cliproxyapi-restart.timer"
    fi

    if [[ -f "$timer_file" ]]; then
        grep '^OnCalendar=' "$timer_file" | head -1 | cut -d'=' -f2-
    fi
}

reload_systemd_user_daemon() {
    local reload_output=""

    if reload_output=$(systemctl --user daemon-reload 2>&1); then
        log_success "Reloaded systemd user daemon"
        return 0
    fi

    log_warning "Could not reload systemd user daemon automatically"
    if [[ -n "$reload_output" ]]; then
        echo "$reload_output"
    fi
    return 1
}

show_restart_timer_manual_steps() {
    echo
    log_info "If your VPS has not enabled lingering yet, run:"
    log_info "  sudo loginctl enable-linger \$(whoami)"
    log_info "Then reload and enable the timer manually:"
    log_info "  systemctl --user daemon-reload"
    log_info "  systemctl --user enable --now cliproxyapi-restart.timer"
    log_info "  systemctl --user list-timers --all | grep -F cliproxyapi-restart"
    echo
}

is_restart_timer_enabled() {
    systemctl --user is-enabled --quiet cliproxyapi-restart.timer 2>/dev/null
}

create_restart_timer_units() {
    local install_dir="$1"
    local systemd_dir
    systemd_dir=$(get_systemd_user_dir)
    local systemctl_bin
    systemctl_bin=$(get_systemctl_bin)
    local timezone
    timezone=$(get_system_timezone)
    local on_calendar
    on_calendar=$(get_restart_timer_calendar "$timezone")
    local restart_service_file="${install_dir}/cliproxyapi-restart.service"
    local restart_timer_file="${install_dir}/cliproxyapi-restart.timer"

    log_info "Creating daily restart timer files..."
    mkdir -p "$systemd_dir"

    cat > "$restart_service_file" << EOF
[Unit]
Description=Restart ${REPO_NAME} Service (user)

[Service]
Type=oneshot
ExecStart=${systemctl_bin} --user restart cliproxyapi.service
EOF

    cat > "$restart_timer_file" << EOF
[Unit]
Description=Daily restart for ${REPO_NAME} at Asia/Shanghai 04:00

[Timer]
# Target schedule: Asia/Shanghai 04:00 every day.
# On systems using UTC, that corresponds to 20:00 UTC on the previous day.
OnCalendar=${on_calendar}
Persistent=true

[Install]
WantedBy=timers.target
EOF

    cp "$restart_service_file" "${systemd_dir}/cliproxyapi-restart.service"
    cp "$restart_timer_file" "${systemd_dir}/cliproxyapi-restart.timer"

    RESTART_TIMER_TIMEZONE="$timezone"
    RESTART_TIMER_ON_CALENDAR="$on_calendar"
    log_success "Daily restart timer files created"
}

setup_restart_timer() {
    local install_dir="$1"
    local enable_on_install="$2"
    local enable_output=""

    create_restart_timer_units "$install_dir"

    if ! reload_systemd_user_daemon; then
        if [[ "$enable_on_install" == "true" ]]; then
            RESTART_TIMER_STATUS="enable_failed"
        else
            RESTART_TIMER_STATUS="refresh_failed"
        fi
        show_restart_timer_manual_steps
        return 0
    fi

    if [[ "$enable_on_install" != "true" ]]; then
        RESTART_TIMER_STATUS="refreshed"
        log_info "Refreshed daily restart timer definition without changing enabled state"
        return 0
    fi

    log_info "Enabling daily restart timer..."
    if enable_output=$(systemctl --user enable --now cliproxyapi-restart.timer 2>&1); then
        RESTART_TIMER_STATUS="enabled"
        log_success "Enabled daily restart timer for Asia/Shanghai 04:00"
        log_info "Check next run: systemctl --user list-timers --all | grep -F cliproxyapi-restart"
        return 0
    fi

    RESTART_TIMER_STATUS="enable_failed"
    log_warning "Failed to enable daily restart timer automatically"
    if [[ -n "$enable_output" ]]; then
        echo "$enable_output"
    fi
    show_restart_timer_manual_steps
}

show_restart_timer_summary() {
    case "$RESTART_TIMER_STATUS" in
        "enabled")
            log_info "Daily restart is enabled for Asia/Shanghai 04:00 (timezone=${RESTART_TIMER_TIMEZONE}, OnCalendar=${RESTART_TIMER_ON_CALENDAR})"
            ;;
        "refreshed")
            log_info "Daily restart timer definition refreshed (timezone=${RESTART_TIMER_TIMEZONE}, enabled state unchanged)"
            ;;
        "enable_failed")
            log_warning "Daily restart timer files were created, but automatic enabling did not complete"
            ;;
        "refresh_failed")
            log_warning "Daily restart timer files were updated, but systemd did not reload automatically"
            ;;
    esac
}

